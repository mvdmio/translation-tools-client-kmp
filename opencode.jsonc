{
  "$schema": "https://opencode.ai/config.json",

  // Load repo-specific operating instructions automatically.
  "instructions": ["AGENTS.md"],

  // Keep noisy generated directories out of file watching.
  "watcher": {
    "ignore": [
      ".git/**",
      ".gradle/**",
      "build/**",
      "**/build/**"
    ]
  },

  // Shortcuts for the common Gradle workflows used in this repo.
  "command": {
    "build": {
      "description": "Build the library",
      "agent": "build",
      "template": "Build this repository with the Gradle wrapper appropriate for the current platform. Prefer `./gradlew.bat build` on Windows and `./gradlew build` elsewhere. Quote the important failures, fix them, and finish with the final result."
    },
    "test": {
      "description": "Run automated tests",
      "agent": "build",
      "template": "Run the test suite for this repository with the Gradle wrapper appropriate for the current platform. Prefer `./gradlew.bat allTests` on Windows and `./gradlew allTests` elsewhere. Quote failing tests or key passing results and fix issues before finishing."
    },
    "verify": {
      "description": "Run full verification",
      "agent": "build",
      "template": "Verify this repository end to end. Run the Gradle wrapper appropriate for the current platform, using `build` as the default full verification command. Confirm README and version updates when the change affects the published library, then report the final status succinctly."
    }
  }
}
